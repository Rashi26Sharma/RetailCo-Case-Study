function buildHeatmap(tableId, data) {
  const t = document.getElementById(tableId);
  const thead = t.createTHead();
  const hrow = thead.insertRow();
  hrow.insertCell().textContent = '';
  HM_LABELS.forEach(l => {
    const th = document.createElement('th');
    th.textContent = l.replace('\n', ' ');
    hrow.appendChild(th);
  });
  const tbody = t.createTBody();
  data.forEach((row, i) => {
    const tr = tbody.insertRow();
    const lc = tr.insertCell();
    lc.className = 'label';
    lc.textContent = row.label;
    row.vals.forEach((v, j) => {
      const td = tr.insertCell();
      td.className = 'hm-cell';
      const pct = Math.round(v * 100);
      const alpha = 0.3 + v * 0.7;
      td.style.background = HM_COLS[j][0];
      td.style.opacity = (0.4 + v * 0.6).toFixed(2);
      td.style.color = HM_COLS[j][1];
      td.textContent = pct + '%';
      td.title = HM_LABELS[j].replace('\n',' ') + ': ' + pct + '%';
    });
  });
}
